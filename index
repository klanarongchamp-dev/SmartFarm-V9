// Save functions
function saveRain() { localStorage.setItem('rainLimit', $('inp-rain').value); toast('💾 บันทึก Rain Limit'); addLog('⚙️', 'Rain Limit: ' + $('inp-rain').value, 'system'); closeSub(); }
function saveSchedule() {
  const schedules = [];
  for (let i = 0; $('sched-time-' + i); i++) {
    schedules.push({ time: $('sched-time-' + i).value, duration: Number($('sched-dur-' + i).value) || 10 });
  }
  localStorage.setItem('schedules', JSON.stringify(schedules));
  localStorage.setItem('scheduleEnable', $('inp-sched-en').checked);
  localStorage.setItem('schedSkipRain', $('inp-skip-rain').checked);
  localStorage.setItem('schedSkipSoil', $('inp-skip-soil').checked);
  const days = [...$('sub-content').querySelectorAll('#day-picks button.bg-green-500')].map(b => b.textContent);
  localStorage.setItem('schedDays', JSON.stringify(days));
  toast('💾 บันทึก Schedule');
  addLog('⚙️', 'Schedule saved', 'system');
  closeSub();
}
function saveFarm() {
  localStorage.setItem('plantName', sanitize($('inp-pname').value));
  localStorage.setItem('plantDate', $('inp-pdate').value);
  localStorage.setItem('farmLoc', $('inp-loc').value);
