function addNotif(icon, msg) {
  if (localStorage.getItem('notify') !== 'true') return;
  notifications.unshift({ icon, msg, time: new Date().toISOString(), read: false });
  if (notifications.length > 50) notifications = notifications.slice(0, 50);
  localStorage.setItem('notifs', JSON.stringify(notifications));
  renderNotifications();
}
function renderNotifications() {
  const el = DOM['notif-list'];
  const empty = DOM['notif-empty'];
  if (notifications.length === 0) { el.innerHTML = ''; empty.style.display = 'block'; return; }
  empty.style.display = 'none';
  el.innerHTML = notifications.slice(0, 30).map(n => {
    const t = new Date(n.time).toLocaleString('th-TH');
    return `<div class="notif-item"><span style="font-size:20px">${n.icon}</span><div style="flex:1"><div class="text-sm">${sanitize(n.msg)}</div><div class="text-xs text-white/40">${t}</div></div></div>`;
  }).join('');
}

