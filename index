   <div class="ios-card-group">
    <div class="ios-card-item" onclick="toggleTheme()">
     <div class="flex items-center gap-3">
      <span>🎨</span><span>Theme</span>
     </div><span id="theme-label" class="text-white/50 text-sm">Auto</span>
