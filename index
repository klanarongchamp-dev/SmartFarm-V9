    <div class="ios-card-item" onclick="openSub('rain')">
     <div class="flex items-center gap-3">
      <span>🌧️</span><span>Rain Limit</span>
     </div><span class="text-white/40">›</span>
    </div>
    <div class="ios-card-item" onclick="openSub('farm')">
     <div class="flex items-center gap-3">
      <span>🌱</span><span>Farm Info</span>
     </div><span class="text-white/40">›</span>
    </div>
   </div>
   <div class="ios-card-group">
    <div class="ios-card-item" onclick="openSub('mqtt')">
     <div class="flex items-center gap-3">
      <span>📡</span><span>MQTT</span>
     </div><span class="text-white/40">›</span>
    </div>
    <div class="ios-card-item" onclick="openSub('weather')">
     <div class="flex items-center gap-3">
      <span>🌤️</span><span>Weather</span>
     </div><span class="text-white/40">›</span>
    </div>
    <div class="ios-card-item" onclick="openSub('telegram')">
     <div class="flex items-center gap-3">
      <span>✈️</span><span>Telegram</span>
     </div><span class="text-white/40">›</span>
    </div>
   </div>
   <div class="ios-card-group">
    <div class="ios-card-item" onclick="openSub('backup')">
     <div class="flex items-center gap-3">
      <span>💾</span><span>Backup / Restore</span>
     </div><span class="text-white/40">›</span>
    </div>
    <div class="ios-card-item" onclick="openSub('about')">
     <div class="flex items-center gap-3">
      <span>ℹ️</span><span>About</span>
     </div><span class="text-white/40">›</span>
