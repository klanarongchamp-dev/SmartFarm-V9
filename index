:root{--vh:1vh}
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent}
body{font-family:'DM Sans',sans-serif;margin:0;padding:0;overflow-x:hidden;transition:background .8s,color .3s;text-rendering:optimizeLegibility}
body.theme-day{background:linear-gradient(160deg,#064e3b,#065f46,#047857)}
body.theme-night{background:linear-gradient(160deg,#0f172a,#1e1b4b,#0f172a)}
.page{display:none;padding:16px 16px 90px;animation:fadeIn .3s}.page.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* Splash */
#splash{position:fixed;inset:0;background:linear-gradient(135deg,#0f172a 0%,#064e3b 50%,#14532d 100%);display:flex;flex-direction:column;justify-content:center;align-items:center;z-index:99999;transition:opacity .8s,transform .5s}
#splash.fadeout{opacity:0;transform:scale(1.05);pointer-events:none}
.splash-icon{font-size:72px;animation:splashPulse 1.5s ease-in-out infinite}
@keyframes splashPulse{0%,100%{transform:scale(1)}50%{transform:scale(1.1)}}
.splash-bar{width:200px;height:3px;background:rgba(255,255,255,.15);border-radius:4px;margin-top:24px;overflow:hidden}
.splash-bar-inner{height:100%;background:linear-gradient(90deg,#4ade80,#22d3ee);border-radius:4px;animation:splashLoad 2s ease-in-out forwards}
@keyframes splashLoad{from{width:0}to{width:100%}}

/* Toast */
.toast-msg{position:fixed;top:16px;left:16px;right:16px;padding:14px 20px;border-radius:16px;background:rgba(30,41,59,.95);backdrop-filter:blur(12px);color:#fff;text-align:center;z-index:100000;font-weight:500;transform:translateY(-100px);opacity:0;transition:transform .3s,opacity .3s;pointer-events:none}
.toast-msg.show{transform:translateY(0);opacity:1;pointer-events:auto}

/* Glass */
.glass{background:rgba(255,255,255,.07);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,.1);border-radius:20px;transition:transform .2s,box-shadow .2s}
.glass:hover{transform:translateY(-2px);box-shadow:0 8px 32px rgba(0,0,0,.2)}
.glass-strong{background:rgba(255,255,255,.1);backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,.15);border-radius:24px}

/* Weather Hero */
.weather-hero{border-radius:28px;padding:28px 24px;text-align:center;background:linear-gradient(135deg,rgba(255,255,255,.08),rgba(255,255,255,.03));backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,.12);position:relative;overflow:hidden}
.weather-hero::before{content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;background:radial-gradient(circle,rgba(74,222,128,.05) 0%,transparent 60%);animation:weatherGlow 8s ease-in-out infinite}
@keyframes weatherGlow{0%,100%{transform:translate(0,0)}50%{transform:translate(5%,5%)}}
.weather-hero .temp{font-size:64px;font-weight:700;line-height:1}
.weather-hero .condition{font-size:16px;opacity:.8;margin-top:4px}
.weather-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:16px}
.weather-stat{text-align:center;padding:8px 4px;border-radius:12px;background:rgba(255,255,255,.05)}
.weather-stat .ws-val{font-size:14px;font-weight:600}
.weather-stat .ws-label{font-size:10px;opacity:.5;margin-top:2px}

/* Pump Ring */
.pump-ring{width:180px;height:180px;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;position:relative;transition:transform .2s,box-shadow .3s;background:rgba(255,255,255,.06);backdrop-filter:blur(16px)}
.pump-ring:active{transform:scale(.92)}
.pump-ring::before{content:'';position:absolute;inset:-5px;border-radius:50%;border:4px solid transparent;transition:all .6s}
.pump-ring.on::before{border-color:#4ade80;box-shadow:0 0 40px #4ade80,0 0 80px rgba(74,222,128,.2);animation:pulseG 2s infinite}
.pump-ring.off::before{border-color:#f87171;box-shadow:0 0 20px rgba(248,113,113,.3)}
.pump-ring.sending::before{border-color:#fbbf24;animation:pulseSend 1s infinite}
@keyframes pulseG{0%,100%{box-shadow:0 0 40px #4ade80,0 0 80px rgba(74,222,128,.2)}50%{box-shadow:0 0 60px #4ade80,0 0 100px rgba(74,222,128,.3)}}
@keyframes pulseSend{0%,100%{opacity:1}50%{opacity:.4}}

.pump-stats{display:flex;justify-content:center;gap:32px;margin-top:16px;font-size:13px;opacity:.7}
.pump-stats .stat-val{font-size:20px;font-weight:700;opacity:1}

/* Quick Actions */
.quick-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.quick-btn{background:rgba(255,255,255,.07);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.1);border-radius:16px;padding:14px 8px;text-align:center;cursor:pointer;transition:transform .15s,background .2s}
.quick-btn:active{transform:scale(.9);background:rgba(255,255,255,.15)}
.quick-btn .qicon{font-size:24px}
.quick-btn .qlabel{font-size:11px;margin-top:4px;opacity:.7}
.quick-btn.active-timer{border-color:#4ade80;background:rgba(74,222,128,.1)}

/* Sensor */
.sensor-card{transition:transform .2s,box-shadow .2s}
.sensor-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.2)}
.sensor-val{transition:color .3s}
.sensor-val.warn{color:#fbbf24!important}
.sensor-val.danger{color:#f87171!important}

/* Skeleton */
.skeleton{background:linear-gradient(90deg,rgba(255,255,255,.05) 25%,rgba(255,255,255,.1) 50%,rgba(255,255,255,.05) 75%);background-size:200% 100%;animation:shimmer 1.5s infinite;border-radius:8px}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}

/* Timeline */
.timeline-item{display:flex;gap:12px;position:relative;padding-bottom:14px}
.timeline-item:not(:last-child)::after{content:'';position:absolute;left:13px;top:30px;bottom:0;width:2px;background:rgba(255,255,255,.1)}
.timeline-dot{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0}

/* iOS Cards */
.ios-card-group{background:rgba(255,255,255,.07);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,.1);border-radius:16px;overflow:hidden;margin-bottom:16px}
.ios-card-item{display:flex;align-items:center;justify-content:space-between;padding:14px 16px;border-bottom:1px solid rgba(255,255,255,.05);cursor:pointer;transition:background .15s}
.ios-card-item:active{background:rgba(255,255,255,.05)}
.ios-card-item:last-child{border-bottom:none}
.toggle{width:50px;height:28px;border-radius:14px;background:#4b5563;position:relative;cursor:pointer;transition:background .3s}
.toggle.on{background:#22c55e}
.toggle::after{content:'';position:absolute;top:3px;left:3px;width:22px;height:22px;border-radius:50%;background:#fff;transition:transform .3s;box-shadow:0 2px 4px rgba(0,0,0,.2)}
.toggle.on::after{transform:translateX(22px)}

/* Bottom Nav */
.bottom-nav{position:fixed;bottom:0;left:0;right:0;height:72px;background:rgba(15,23,42,.95);backdrop-filter:blur(20px);display:flex;justify-content:space-around;align-items:center;z-index:9999;border-top:1px solid rgba(255,255,255,.08)}
.nav-btn{background:none;border:none;color:rgba(255,255,255,.45);font-size:11px;display:flex;flex-direction:column;align-items:center;gap:3px;padding:8px 12px;transition:color .2s,transform .2s;cursor:pointer}
.nav-btn:active{transform:scale(.9)}
.nav-btn.active{color:#4ade80}
.nav-btn .nav-icon{font-size:22px}

/* Status colors */
.status-on{color:#4ade80}.status-off{color:#f87171}.status-warn{color:#fbbf24}.status-reconnect{color:#fb923c}

/* Connection indicator */
.conn-dot{width:8px;height:8px;border-radius:50%;display:inline-block;margin-right:6px}
.conn-dot.online{background:#4ade80;box-shadow:0 0 6px #4ade80}
.conn-dot.offline{background:#f87171}
.conn-dot.reconnecting{background:#fb923c;animation:blink 1s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}

/* Sub overlay */
#sub-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);backdrop-filter:blur(8px);z-index:10000;overflow-y:auto;padding:20px;animation:fadeIn .2s}
.sub-input{width:100%;margin-top:4px;padding:12px 16px;border-radius:12px;background:rgba(255,255,255,.08);color:#fff;border:1px solid rgba(255,255,255,.15);font-size:14px;outline:none;transition:border-color .2s}
.sub-input:focus{border-color:#4ade80}
.sub-btn{width:100%;padding:12px;border-radius:12px;font-weight:600;border:none;cursor:pointer;transition:transform .1s,opacity .2s}
.sub-btn:active{transform:scale(.97)}
.sub-btn-green{background:#22c55e;color:#fff}
.sub-btn-blue{background:#3b82f6;color:#fff}
.sub-btn-orange{background:#f97316;color:#fff}
.sub-btn-red{background:#ef4444;color:#fff}

/* Notifications */
.notif-item{padding:12px 16px;border-bottom:1px solid rgba(255,255,255,.05);display:flex;gap:12px;align-items:flex-start}
.notif-item:last-child{border-bottom:none}

/* History controls */
.filter-bar{display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap}
.filter-bar input,.filter-bar select{padding:8px 12px;border-radius:10px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);color:#fff;font-size:13px;outline:none}
.filter-bar button{padding:8px 14px;border-radius:10px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.12);color:#fff;font-size:13px;cursor:pointer}

/* Countdown */
.countdown-badge{position:absolute;top:-8px;right:-8px;background:#22c55e;color:#fff;font-size:10px;font-weight:700;padding:2px 6px;border-radius:8px;min-width:20px;text-align:center}
  </style>
