  CONFIG.mqtt.user = $('inp-mqtt-user').value || CONFIG.mqtt.user;
  CONFIG.mqtt.pass = $('inp-mqtt-pass').value || CONFIG.mqtt.pass;
  connectMQTT();
  closeSub();
}
function saveWeather() {
  localStorage.setItem('wLat', $('inp-wlat').value);
  localStorage.setItem('wLon', $('inp-wlon').value);
  CONFIG.weather.lat = parseFloat($('inp-wlat').value);
