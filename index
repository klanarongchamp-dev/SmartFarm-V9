function saveTelegram() {
  localStorage.setItem('tgToken', $('inp-tgtoken').value);
  localStorage.setItem('tgChat', $('inp-tgchat').value);
  toast('💾 บันทึก Telegram'); closeSub();
}
async function testTelegram() {
  const token = $('inp-tgtoken').value || localStorage.getItem('tgToken');
  const chat = $('inp-tgchat').value || localStorage.getItem('tgChat');
  if (!token || !chat) { toast('❌ กรุณาใส่ Token และ Chat ID'); return; }
  try {
    await fetch(`https://api.telegram.org/bot${token}/sendMessage`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ chat_id: chat, text: '🌱 ทดสอบจาก Smart Farm V12.1A' }) });
    toast('✅ ส่งข้อความสำเร็จ');
  } catch (e) { toast('❌ ส่งไม่สำเร็จ'); }
}

function doBackup() {
  const data = {};
  for (let i = 0; i < localStorage.length; i++) { const k = localStorage.key(i); data[k] = localStorage.getItem(k); }
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'smartfarm_backup_' + new Date().toISOString().slice(0, 10) + '.json';
  a.click();
  toast('📥 Export สำเร็จ');
}
function doRestore() {
  const inp = document.createElement('input');
  inp.type = 'file'; inp.accept = '.json';
  inp.onchange = e => {
    const f = e.target.files[0]; if (!f) return;
    const r = new FileReader();
    r.onload = ev => {
      try {
        const d = JSON.parse(ev.target.result);
        if (typeof d !== 'object' || Array.isArray(d)) throw new Error('Invalid');
        Object.keys(d).forEach(k => localStorage.setItem(k, d[k]));
        toast('📤 Import สำเร็จ - รีโหลด...');
        setTimeout(() => location.reload(), 1000);
      } catch (e) { toast('❌ ไฟล์ไม่ถูกต้อง'); }
    };
    r.readAsText(f);
  };
  inp.click();
}

// ═══════════════════ SCHEDULE CHECK ═══════════════════
function checkSchedule() {
  if (localStorage.getItem('scheduleEnable') !== 'true') return;
  const schedules = JSON.parse(localStorage.getItem('schedules') || '[]');
  const days = JSON.parse(localStorage.getItem('schedDays') || '[]');
  const now = new Date();
  const dayNames = ['sun', 'mon', 'tue', 'wed', 'thu', 'fri', 'sat'];
  if (!days.includes(dayNames[now.getDay()])) return;
  const hhmm = now.toTimeString().slice(0, 5);
  for (const s of schedules) {
    if (hhmm === s.time) {
      if (localStorage.getItem('schedSkipRain') === 'true') { /* would check rain */ }
      safePub(CONFIG.mqtt.topics.pumpCmd, 'ON');
      addLog('🕒', 'Schedule ON ' + s.time, 'pump');
      if (s.duration) setTimeout(() => { safePub(CONFIG.mqtt.topics.pumpCmd, 'OFF'); addLog('🕒', 'Schedule OFF', 'pump'); }, s.duration * 60000);
      break;
    }
  }
}

