   </div>
  </div><!-- Sub overlay -->
  <div id="sub-overlay">
   <div class="glass-strong p-5" style="max-width:400px;margin:40px auto">
    <div class="flex justify-between items-center mb-4">
     <h3 id="sub-title" class="font-bold text-lg"></h3><button onclick="closeSub()" style="background:none;border:none;color:rgba(255,255,255,.6);font-size:24px;cursor:pointer">×</button>
    </div>
    <div id="sub-content"></div>
   </div>
  </div><!-- Bottom Nav -->
  <nav class="bottom-nav" data-template-id="bottom-nav" style="background: rgba(15, 23, 42, 0.95);"><button class="nav-btn active" onclick="showPage('home',this)"><span class="nav-icon">🏠</span>Home</button> <button class="nav-btn" onclick="showPage('history',this)"><span class="nav-icon">📈</span>History</button> <button class="nav-btn" onclick="showPage('notif',this)"><span class="nav-icon">🔔</span>Notif</button> <button class="nav-btn" onclick="showPage('settings',this)"><span class="nav-icon">⚙️</span>Settings</button>
  </nav>
  <script src="/_sdk/editing_sdk.js"></script>
  <script>
// ═══════════════════ CONSTANTS ═══════════════════
const CONFIG = {
  mqtt: {
    url: 'wss://650188a0ee2b4367b7c131fb385590a9.s1.eu.hivemq.cloud:8884/mqtt',
    user: atob('c21hcnRmYXJt'),
    pass: atob('S2xhMTIzNDU='),
    topics: { pumpStatus: 'farm/pump/status', pumpCmd: 'farm/pump', sensor: 'farm/sensor/#', heartbeat: 'farm/heartbeat' },
    reconnectPeriod: 3000,
    heartbeatTimeout: 90000
  },
  weather: {
    lat: 14.0208,
    lon: 100.5250,
    interval: 600000,
    retryDelay: 30000,
    maxRetries: 3
  },
  thresholds: { tempHigh: 40, tempLow: 10, humLow: 30, soilLow: 20 },
  maxLogs: 100
};

// ═══════════════════ STATE ═══════════════════
let pumpState = 'OFF', pumpStartTime = null, pumpSending = false;
let quickTimer = null, quickEndTime = null;
let pumpTodaySeconds = Number(localStorage.getItem('pumpToday') || 0);
const todayKey = new Date().toDateString();
if (localStorage.getItem('pumpTodayKey') !== todayKey) { pumpTodaySeconds = 0; localStorage.setItem('pumpTodayKey', todayKey); }
let logs = JSON.parse(localStorage.getItem('logs') || '[]');
let notifications = JSON.parse(localStorage.getItem('notifs') || '[]');
let mqttStatus = 'offline'; // online, offline, reconnecting
let lastNodeSeen = Number(localStorage.getItem('lastNodeSeen') || 0);
let nodeOnline = false;
let publishQueue = [];
let lastPublish = {};
let weatherRetries = 0;
let themeMode = localStorage.getItem('themeMode') || 'auto';

// ═══════════════════ DOM CACHE ═══════════════════
const $ = id => document.getElementById(id);
const DOM = {};
document.addEventListener('DOMContentLoaded', () => {
  ['greeting-text','greeting-date','hero-temp','hero-condition','weather-icon','weather-updated',
   'ws-hum','ws-rain','ws-wind','ws-dir','ws-pressure','ws-uv','ws-cloud','ws-feels','ws-vis',
   'pump-ring','pump-label','pump-runtime','pump-today','pump-countdown','pump-sending','node-lastseen',
   'val-temp','val-hum','val-soil','val-light','val-rssi','val-node','sensor-updated',
   'timeline-list','history-list','notif-list','notif-empty',
   'conn-dot','conn-text','toast'].forEach(id => DOM[id] = $(id));
  init();
});

// ═══════════════════ INIT ═══════════════════
function init() {
  applyTheme();
  updateGreeting();
  initToggles();
  renderTimeline();
  renderNotifications();
  connectMQTT();
  loadWeather();
  // Merged intervals
  setInterval(tick, 1000);
  setInterval(updateGreeting, 60000);
  setInterval(loadWeather, CONFIG.weather.interval);
  setInterval(checkHeartbeat, 30000);
  setInterval(checkSchedule, 30000);
  // Splash
  setTimeout(() => { const s = $('splash'); s.classList.add('fadeout'); setTimeout(() => s.remove(), 800); }, 2200);
}

// ═══════════════════ THEME ═══════════════════
function applyTheme() {
  document.body.classList.remove('theme-day', 'theme-night');
  if (themeMode === 'day') document.body.classList.add('theme-day');
  else if (themeMode === 'night') document.body.classList.add('theme-night');
  else { const h = new Date().getHours(); document.body.classList.add(h >= 6 && h < 18 ? 'theme-day' : 'theme-night'); }
  if ($('theme-label')) $('theme-label').textContent = themeMode === 'auto' ? 'Auto' : themeMode === 'day' ? 'Day' : 'Night';
}
function toggleTheme() {
  const modes = ['auto', 'day', 'night'];
  themeMode = modes[(modes.indexOf(themeMode) + 1) % 3];
  localStorage.setItem('themeMode', themeMode);
  applyTheme();
  toast('🎨 Theme: ' + themeMode);
}

// ═══════════════════ NAV ═══════════════════
function showPage(name, btn) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  $('page-' + name).classList.add('active');
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
}

// ═══════════════════ TOAST ═══════════════════
let toastTimeout;
function toast(msg) {
  DOM['toast'].textContent = msg;
  DOM['toast'].classList.add('show');
  clearTimeout(toastTimeout);
  toastTimeout = setTimeout(() => DOM['toast'].classList.remove('show'), 3000);
}

// ═══════════════════ GREETING ═══════════════════
function updateGreeting() {
  const h = new Date().getHours();
  let g = 'สวัสดีตอนค่ำ 🌙';
  if (h >= 5 && h < 12) g = 'อรุณสวัสดิ์ ☀️';
  else if (h >= 12 && h < 17) g = 'สวัสดีตอนบ่าย 🌤️';
  DOM['greeting-text'].textContent = g;
  const d = new Date();
  DOM['greeting-date'].textContent = d.toLocaleDateString('th-TH', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
}

// ═══════════════════ MQTT ═══════════════════
let client;
function connectMQTT() {
  updateConnStatus('reconnecting');
  client = mqtt.connect(CONFIG.mqtt.url, {
    username: CONFIG.mqtt.user,
    password: CONFIG.mqtt.pass,
    reconnectPeriod: CONFIG.mqtt.reconnectPeriod,
    connectTimeout: 10000
  });
  client.on('connect', () => {
    updateConnStatus('online');
    client.subscribe([CONFIG.mqtt.topics.pumpStatus, CONFIG.mqtt.topics.sensor, CONFIG.mqtt.topics.heartbeat]);
    addLog('📡', 'MQTT Connected', 'mqtt');
    addNotif('📡', 'เชื่อมต่อ MQTT สำเร็จ');
    flushQueue();
  });
  client.on('offline', () => { updateConnStatus('offline'); addNotif('⚠️', 'MQTT Offline'); });
  client.on('reconnect', () => updateConnStatus('reconnecting'));
  client.on('error', (err) => { updateConnStatus('offline'); addLog('❌', 'MQTT Error', 'mqtt'); });
  client.on('close', () => updateConnStatus('offline'));
  client.on('message', handleMessage);
}

function updateConnStatus(status) {
  mqttStatus = status;
  const dot = DOM['conn-dot'], txt = DOM['conn-text'];
  dot.className = 'conn-dot ' + (status === 'online' ? 'online' : status === 'reconnecting' ? 'reconnecting' : 'offline');
  txt.textContent = status === 'online' ? 'Online' : status === 'reconnecting' ? 'Reconnecting...' : 'Offline';
}

function safePub(topic, msg) {
  const now = Date.now();
  const key = topic + '|' + msg;
  if (lastPublish[key] && now - lastPublish[key] < 2000) return; // dedup
  lastPublish[key] = now;
  if (client && client.connected) {
    client.publish(topic, msg);
  } else {
    publishQueue.push({ topic, msg, time: now });
    toast('📡 คำสั่งอยู่ในคิว (MQTT Offline)');
  }
}
function flushQueue() {
  while (publishQueue.length > 0) {
    const cmd = publishQueue.shift();
    if (Date.now() - cmd.time < 300000) client.publish(cmd.topic, cmd.msg);
  }
}

function handleMessage(topic, msg) {
  const payload = msg.toString();
  if (topic === CONFIG.mqtt.topics.pumpStatus) {
    const prev = pumpState;
    pumpState = payload;
    pumpSending = false;
    updatePumpUI();
    if (prev !== pumpState) {
      if (pumpState === 'ON') { pumpStartTime = Date.now(); addLog('🟢', 'Pump ON', 'pump'); addNotif('🚰', 'เปิดปั๊มน้ำ'); }
      else { if (pumpStartTime) { pumpTodaySeconds += Math.round((Date.now() - pumpStartTime) / 1000); pumpStartTime = null; localStorage.setItem('pumpToday', pumpTodaySeconds); } addLog('🔴', 'Pump OFF', 'pump'); addNotif('🛑', 'ปิดปั๊มน้ำ'); }
    }
  } else if (topic === CONFIG.mqtt.topics.heartbeat || topic.startsWith('farm/sensor')) {
    lastNodeSeen = Date.now();
    localStorage.setItem('lastNodeSeen', lastNodeSeen);
    if (!nodeOnline) { nodeOnline = true; DOM['val-node'].textContent = 'ONLINE'; DOM['val-node'].className = 'font-bold text-xl mt-1 status-on'; }
    if (topic.startsWith('farm/sensor')) {
      try { const d = JSON.parse(payload); updateSensors(d); } catch (e) {}
    }
  }
}

function updateSensors(d) {
  if (d.temp != null) updateSensorVal('val-temp', d.temp, '°C', CONFIG.thresholds.tempHigh, CONFIG.thresholds.tempLow);
  if (d.hum != null) updateSensorVal('val-hum', d.hum, '%', null, CONFIG.thresholds.humLow);
  if (d.soil != null) updateSensorVal('val-soil', d.soil, '%', null, CONFIG.thresholds.soilLow);
  if (d.light != null) { DOM['val-light'].textContent = d.light + ' lux'; }
  if (d.rssi != null) { DOM['val-rssi'].textContent = d.rssi + ' dBm'; DOM['val-rssi'].className = 'font-bold text-xl mt-1 sensor-val' + (d.rssi < -80 ? ' warn' : ''); }
  DOM['sensor-updated'].textContent = 'Sensor: ' + new Date().toLocaleTimeString('th-TH');
}

function updateSensorVal(id, val, suffix, highThresh, lowThresh) {
  const el = DOM[id];
  el.textContent = val + suffix;
  let cls = 'font-bold text-xl mt-1 sensor-val';
  if (highThresh != null && val >= highThresh) cls += ' danger';
  else if (lowThresh != null && val <= lowThresh) cls += ' warn';
  el.className = cls;
}

function checkHeartbeat() {
  if (lastNodeSeen && Date.now() - lastNodeSeen > CONFIG.mqtt.heartbeatTimeout) {
    if (nodeOnline) {
      nodeOnline = false;
      DOM['val-node'].textContent = 'OFFLINE';
      DOM['val-node'].className = 'font-bold text-xl mt-1 status-off';
      addNotif('⚠️', 'Node ไม่ตอบสนอง');
      addLog('⚠️', 'Node Timeout', 'system');
    }
  }
  // Update last seen display
  if (lastNodeSeen) {
    const ago = Math.round((Date.now() - lastNodeSeen) / 1000);
    DOM['node-lastseen'].textContent = ago < 60 ? ago + 's' : Math.round(ago / 60) + 'm';
  }
}

// ═══════════════════ PUMP ═══════════════════
function updatePumpUI() {
  const ring = DOM['pump-ring'], label = DOM['pump-label'];
  ring.classList.remove('on', 'off', 'sending');
  if (pumpSending) { ring.classList.add('sending'); label.textContent = '...'; label.className = 'font-bold mt-1 text-lg status-warn'; }
  else if (pumpState === 'ON') { ring.classList.add('on'); label.textContent = 'ON'; label.className = 'font-bold mt-1 text-lg status-on'; }
  else { ring.classList.add('off'); label.textContent = 'OFF'; label.className = 'font-bold mt-1 text-lg status-off'; }
}

function handlePumpToggle() {
  if (pumpSending) return;
  if (pumpState === 'ON') { safePub(CONFIG.mqtt.topics.pumpCmd, 'OFF'); toast('🛑 ปิดปั๊ม'); }
  else { safePub(CONFIG.mqtt.topics.pumpCmd, 'ON'); toast('🚰 เปิดปั๊ม'); }
  pumpSending = true;
  updatePumpUI();
  setTimeout(() => { if (pumpSending) { pumpSending = false; updatePumpUI(); } }, 5000);
}

function quickPump(mins) {
  if (quickTimer) { clearTimeout(quickTimer); quickTimer = null; }
  document.querySelectorAll('.quick-btn').forEach(b => b.classList.remove('active-timer'));
  $('qb-' + mins).classList.add('active-timer');
  safePub(CONFIG.mqtt.topics.pumpCmd, 'ON');
  toast('🚿 เปิดปั๊ม ' + mins + ' นาที');
  addLog('🚿', 'Quick ' + mins + ' min', 'pump');
  quickEndTime = Date.now() + mins * 60000;
  DOM['pump-countdown'].style.display = 'block';
  quickTimer = setTimeout(() => {
    safePub(CONFIG.mqtt.topics.pumpCmd, 'OFF');
    toast('🛑 ปิดปั๊มอัตโนมัติ');
    addLog('🔴', 'Auto OFF ' + mins + ' min', 'pump');
    quickTimer = null; quickEndTime = null;
    DOM['pump-countdown'].style.display = 'none';
    document.querySelectorAll('.quick-btn').forEach(b => b.classList.remove('active-timer'));
  }, mins * 60000);
}

// ═══════════════════ TICK (1s) ═══════════════════
function tick() {
  // Pump runtime
  let runtime = 0;
  if (pumpState === 'ON' && pumpStartTime) runtime = Math.round((Date.now() - pumpStartTime) / 1000);
  const m = Math.floor(runtime / 60), s = runtime % 60;
  DOM['pump-runtime'].textContent = String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
  DOM['pump-today'].textContent = Math.round((pumpTodaySeconds + runtime) / 60) + ' min';
  // Quick countdown
  if (quickEndTime) {
    const rem = Math.max(0, Math.round((quickEndTime - Date.now()) / 1000));
    DOM['pump-countdown'].textContent = '⏱️ ' + Math.floor(rem / 60) + ':' + String(rem % 60).padStart(2, '0');
  }
  // Daily reset
  const dk = new Date().toDateString();
  if (localStorage.getItem('pumpTodayKey') !== dk) { pumpTodaySeconds = 0; localStorage.setItem('pumpTodayKey', dk); localStorage.setItem('pumpToday', 0); }
}

// ═══════════════════ WEATHER ═══════════════════
async function loadWeather() {
  try {
    const url = `https://api.open-meteo.com/v1/forecast?latitude=${CONFIG.weather.lat}&longitude=${CONFIG.weather.lon}&current=temperature_2m,relative_humidity_2m,rain,weather_code,wind_speed_10m,wind_direction_10m,surface_pressure,uv_index,cloud_cover,apparent_temperature`;
    const r = await fetch(url);
    if (!r.ok) throw new Error('HTTP ' + r.status);
    const d = await r.json();
    const c = d.current;
    weatherRetries = 0;
    DOM['hero-temp'].textContent = Math.round(c.temperature_2m) + '°';
    const wc = c.weather_code || 0;
    let icon = '☀️', cond = 'แดดจัด';
    if (wc >= 61) { icon = '🌧️'; cond = 'ฝนตก'; } else if (wc >= 51) { icon = '🌦️'; cond = 'ฝนปรอย'; } else if (wc >= 3) { icon = '☁️'; cond = 'มีเมฆ'; } else if (wc >= 1) { icon = '⛅'; cond = 'เมฆบางส่วน'; }
    DOM['weather-icon'].textContent = icon;
    DOM['hero-condition'].textContent = cond;
    DOM['weather-updated'].textContent = 'อัปเดต: ' + new Date().toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit' });
    DOM['ws-hum'].textContent = Math.round(c.relative_humidity_2m) + '%';
    DOM['ws-rain'].textContent = (c.rain || 0) + ' mm';
    DOM['ws-wind'].textContent = Math.round(c.wind_speed_10m) + ' km/h';
    DOM['ws-dir'].textContent = degToDir(c.wind_direction_10m);
    DOM['ws-pressure'].textContent = Math.round(c.surface_pressure) + ' hPa';
    DOM['ws-uv'].textContent = c.uv_index != null ? c.uv_index.toFixed(1) : '--';
    DOM['ws-cloud'].textContent = (c.cloud_cover || 0) + '%';
    DOM['ws-feels'].textContent = Math.round(c.apparent_temperature) + '°';
    DOM['ws-vis'].textContent = '--';
    // Update sensor cards from weather
    DOM['val-temp'].textContent = Math.round(c.temperature_2m) + '°C';
    DOM['val-hum'].textContent = Math.round(c.relative_humidity_2m) + '%';
    // Rain auto-off
    const rain = c.rain || 0;
    const limit = Number(localStorage.getItem('rainLimit') || 2);
    if (rain >= limit && localStorage.getItem('autoPump') === 'true' && pumpState === 'ON') {
      safePub(CONFIG.mqtt.topics.pumpCmd, 'OFF');
      toast('🌧️ ฝนตก ปิดปั๊มอัตโนมัติ');
      addLog('🌧', 'Auto OFF rain=' + rain + 'mm', 'weather');
      addNotif('🌧️', 'ฝนตก ' + rain + ' mm - ปิดปั๊มอัตโนมัติ');
    }
    if (rain > 0) addNotif('🌧️', 'ฝนตก ' + rain + ' mm');
  } catch (e) {
    weatherRetries++;
    if (weatherRetries <= CONFIG.weather.maxRetries) setTimeout(loadWeather, CONFIG.weather.retryDelay);
    DOM['hero-condition'].textContent = 'โหลดไม่สำเร็จ';
  }
}

function degToDir(deg) {
  const dirs = ['N', 'NE', 'E', 'SE', 'S', 'SW', 'W', 'NW'];
  return dirs[Math.round(deg / 45) % 8];
}

// ═══════════════════ LOGS ═══════════════════
function addLog(icon, msg, type = 'system') {
  logs.unshift({ icon, msg, type, time: new Date().toISOString() });
  if (logs.length > CONFIG.maxLogs) logs = logs.slice(0, CONFIG.maxLogs);
  localStorage.setItem('logs', JSON.stringify(logs));
  renderTimeline();
}
function clearLogs() { logs = []; localStorage.setItem('logs', '[]'); renderTimeline(); renderHistory(); toast('🗑️ ล้าง Activity แล้ว'); }

const typeColors = { pump: '#4ade80', mqtt: '#60a5fa', weather: '#fbbf24', system: '#a78bfa' };
function renderTimeline() {
  DOM['timeline-list'].innerHTML = logs.slice(0, 10).map(l => {
    const t = new Date(l.time);
    const ts = t.toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit' });
    const color = typeColors[l.type] || '#94a3b8';
    return `<div class="timeline-item"><div class="timeline-dot" style="background:${color}30;border:2px solid ${color}">${l.icon}</div><div style="flex:1"><div class="text-sm text-white/90">${sanitize(l.msg)}</div><div class="text-xs text-white/40">${ts} · ${l.type || ''}</div></div></div>`;
  }).join('');
}

function renderHistory() {
  const search = ($('hist-search')?.value || '').toLowerCase();
  const dateFilter = $('hist-date')?.value || '';
  const typeFilter = $('hist-type')?.value || '';
  const filtered = logs.filter(l => {
    if (search && !l.msg.toLowerCase().includes(search)) return false;
    if (typeFilter && l.type !== typeFilter) return false;
    if (dateFilter && !l.time.startsWith(dateFilter)) return false;
    return true;
  });
  DOM['history-list'].innerHTML = filtered.map(l => {
    const t = new Date(l.time);
    const ts = t.toLocaleString('th-TH');
    const color = typeColors[l.type] || '#94a3b8';
    return `<div class="timeline-item"><div class="timeline-dot" style="background:${color}30;border:2px solid ${color}">${l.icon}</div><div style="flex:1"><div class="text-sm text-white/90">${sanitize(l.msg)}</div><div class="text-xs text-white/40">${ts} · ${l.type || ''}</div></div></div>`;
  }).join('') || '<p class="text-center text-white/40 py-4">ไม่พบข้อมูล</p>';
}

function exportCSV() {
  const rows = [['Time', 'Type', 'Message']];
  logs.forEach(l => rows.push([l.time, l.type, l.msg]));
  const csv = rows.map(r => r.map(c => '"' + String(c).replace(/"/g, '""') + '"').join(',')).join('\n');
  const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
